{
  "name": "chanmi-official",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "pnpm run typecheck && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.functions.json",
    "cf:preview": "pnpm run build && wrangler pages dev dist --persist-to ./.wrangler/state",
    "cf:deploy": "pnpm run build && wrangler pages deploy dist --project-name chanmi",
    "db:migrate:local": "wrangler d1 migrations apply chanmi-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply chanmi-db --remote",
    "wrangler:types": "wrangler types --path ./functions/types.d.ts"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wrangler": "^4.0.0"
  }
}
